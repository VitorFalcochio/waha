# WAHA API key
WAHA_API_KEY=replace_with_your_key

# Dashboard access
WAHA_DASHBOARD_NO_PASSWORD=True
WHATSAPP_SWAGGER_NO_PASSWORD=True

# Engine
WHATSAPP_DEFAULT_ENGINE=WEBJS

# Bot print config
PRINT_MODE=ip
PRINTER_IP=192.168.0.130
PRINTER_PORT=9100
TRIGGER=#IMPRESSAO

# Optional: fixed webhook URL for WAHA
WAHA_WEBHOOK_URL=http://YOUR_PC_IP:8000/waha/webhook
